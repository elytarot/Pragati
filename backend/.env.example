# .env.example — copy to .env and fill all values
# NEVER commit .env to Git

# ── DATABASE ────────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/pragati_db"

# ── REDIS ───────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── JWT SECRETS (generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET="REPLACE_WITH_32_CHAR_RANDOM_STRING"
JWT_REFRESH_SECRET="REPLACE_WITH_ANOTHER_32_CHAR_STRING"
JWT_EXPIRES_IN="8h"
JWT_REFRESH_EXPIRES_IN="30d"

# ── AI PROVIDERS ────────────────────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-api03-..."
OPENAI_API_KEY="sk-..."
GEMINI_API_KEY="AIza..."

# ── CLOUDFLARE R2 (free 10GB/month) ─────────────────────────────
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key"
R2_SECRET_ACCESS_KEY="your-r2-secret-key"
R2_BUCKET_NAME="pragati-files"
R2_PUBLIC_URL="https://pub-XXXXX.r2.dev"

# ── SMS — MSG91 India ───────────────────────────────────────────
MSG91_AUTH_KEY="your-msg91-auth-key"
MSG91_SENDER_ID="PRAGTI"
MSG91_TEMPLATE_ID="your-template-id"

# ── APP ─────────────────────────────────────────────────────────
FRONTEND_URL="http://localhost:5173"
PORT=4000
NODE_ENV="development"
